<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:zeebe="http://camunda.org/schema/zeebe/1.0">
  <message id="msg1" name="reminderMessage">
    <extensionElements>
      <zeebe:subscription correlationKey="= orderId" />
    </extensionElements>
  </message>
  <process id="ni-message-boundary-test" isExecutable="true">
    <startEvent id="start" />
    <scriptTask id="setCorr" scriptFormat="csharp">
      <script>_context.orderId = "order-123"</script>
    </scriptTask>
    <task id="longTask" />
    <boundaryEvent id="msgBoundary" attachedToRef="longTask" cancelActivity="false">
      <messageEventDefinition messageRef="msg1" />
    </boundaryEvent>
    <scriptTask id="handleMessage" scriptFormat="csharp">
      <script>_context.messageReceived = true</script>
    </scriptTask>
    <endEvent id="normalEnd" />
    <endEvent id="msgEnd" />
    <sequenceFlow id="f1" sourceRef="start" targetRef="setCorr" />
    <sequenceFlow id="f2" sourceRef="setCorr" targetRef="longTask" />
    <sequenceFlow id="f3" sourceRef="longTask" targetRef="normalEnd" />
    <sequenceFlow id="f4" sourceRef="msgBoundary" targetRef="handleMessage" />
    <sequenceFlow id="f5" sourceRef="handleMessage" targetRef="msgEnd" />
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="ni-message-boundary-test">
      <bpmndi:BPMNShape id="start_di" bpmnElement="start">
        <dc:Bounds x="180" y="182" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="setCorr_di" bpmnElement="setCorr">
        <dc:Bounds x="260" y="160" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="longTask_di" bpmnElement="longTask">
        <dc:Bounds x="420" y="160" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="msgBoundary_di" bpmnElement="msgBoundary">
        <dc:Bounds x="452" y="222" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="handleMessage_di" bpmnElement="handleMessage">
        <dc:Bounds x="580" y="280" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="normalEnd_di" bpmnElement="normalEnd">
        <dc:Bounds x="612" y="182" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="msgEnd_di" bpmnElement="msgEnd">
        <dc:Bounds x="742" y="302" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="f1_di" bpmnElement="f1">
        <di:waypoint x="216" y="200" />
        <di:waypoint x="260" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f2_di" bpmnElement="f2">
        <di:waypoint x="360" y="200" />
        <di:waypoint x="420" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f3_di" bpmnElement="f3">
        <di:waypoint x="520" y="200" />
        <di:waypoint x="612" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f4_di" bpmnElement="f4">
        <di:waypoint x="470" y="258" />
        <di:waypoint x="470" y="320" />
        <di:waypoint x="580" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f5_di" bpmnElement="f5">
        <di:waypoint x="680" y="320" />
        <di:waypoint x="742" y="320" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
