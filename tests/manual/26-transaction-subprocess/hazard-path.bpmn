<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
             id="Definitions_tx_hazard"
             targetNamespace="http://bpmn.io/schema/bpmn">

  <process id="txHazardPathProcess" isExecutable="true">

    <startEvent id="start" name="Start" />

    <scriptTask id="setupTask" name="Setup" scriptFormat="csharp">
      <script>_context.requestId = "tx-hazard-001"; _context.amount = 500</script>
    </scriptTask>

    <transaction id="paymentTransaction" name="Payment Transaction">
      <startEvent id="tx_start" name="Tx Start" />

      <scriptTask id="validateTask" name="Validate Payment" scriptFormat="csharp">
        <script>_context.validated = true</script>
      </scriptTask>

      <scriptTask id="processTask" name="Process Payment (fails)" scriptFormat="csharp">
        <!-- Intentionally throws to trigger the Hazard path -->
        <script>throw new Exception("Payment processor unavailable")</script>
      </scriptTask>

      <endEvent id="tx_end" name="Tx End" />

      <sequenceFlow id="tsf1" sourceRef="tx_start" targetRef="validateTask" />
      <sequenceFlow id="tsf2" sourceRef="validateTask" targetRef="processTask" />
      <sequenceFlow id="tsf3" sourceRef="processTask" targetRef="tx_end" />
    </transaction>

    <!-- Error boundary on TX host catches the unhandled error escaping the Transaction -->
    <boundaryEvent id="errBoundary" name="Payment Error" attachedToRef="paymentTransaction" cancelActivity="true">
      <errorEventDefinition />
    </boundaryEvent>

    <scriptTask id="recoveryTask" name="Handle Payment Error" scriptFormat="csharp">
      <script>_context.errorHandled = true; _context.fallbackResult = "DECLINED"</script>
    </scriptTask>

    <endEvent id="end" name="End (normal)" />
    <endEvent id="errorEnd" name="End (recovery)" />

    <sequenceFlow id="f1" sourceRef="start" targetRef="setupTask" />
    <sequenceFlow id="f2" sourceRef="setupTask" targetRef="paymentTransaction" />
    <sequenceFlow id="f3" sourceRef="paymentTransaction" targetRef="end" />
    <sequenceFlow id="f4" sourceRef="errBoundary" targetRef="recoveryTask" />
    <sequenceFlow id="f5" sourceRef="recoveryTask" targetRef="errorEnd" />
  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="txHazardPathProcess">
      <bpmndi:BPMNShape id="Shape_start" bpmnElement="start">
        <dc:Bounds x="152" y="112" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_setupTask" bpmnElement="setupTask">
        <dc:Bounds x="240" y="90" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_paymentTransaction" bpmnElement="paymentTransaction" isExpanded="true">
        <dc:Bounds x="390" y="50" width="450" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_tx_start" bpmnElement="tx_start">
        <dc:Bounds x="420" y="112" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_validateTask" bpmnElement="validateTask">
        <dc:Bounds x="500" y="90" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_processTask" bpmnElement="processTask">
        <dc:Bounds x="650" y="90" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_tx_end" bpmnElement="tx_end">
        <dc:Bounds x="802" y="112" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_errBoundary" bpmnElement="errBoundary">
        <dc:Bounds x="822" y="192" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_recoveryTask" bpmnElement="recoveryTask">
        <dc:Bounds x="890" y="270" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_end" bpmnElement="end">
        <dc:Bounds x="912" y="112" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_errorEnd" bpmnElement="errorEnd">
        <dc:Bounds x="1050" y="292" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_f1" bpmnElement="f1">
        <di:waypoint x="188" y="130" />
        <di:waypoint x="240" y="130" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_f2" bpmnElement="f2">
        <di:waypoint x="340" y="130" />
        <di:waypoint x="390" y="130" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_f3" bpmnElement="f3">
        <di:waypoint x="840" y="130" />
        <di:waypoint x="912" y="130" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_f4" bpmnElement="f4">
        <di:waypoint x="840" y="228" />
        <di:waypoint x="890" y="310" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_f5" bpmnElement="f5">
        <di:waypoint x="990" y="310" />
        <di:waypoint x="1050" y="310" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_tsf1" bpmnElement="tsf1">
        <di:waypoint x="456" y="130" />
        <di:waypoint x="500" y="130" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_tsf2" bpmnElement="tsf2">
        <di:waypoint x="600" y="130" />
        <di:waypoint x="650" y="130" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_tsf3" bpmnElement="tsf3">
        <di:waypoint x="750" y="130" />
        <di:waypoint x="802" y="130" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
