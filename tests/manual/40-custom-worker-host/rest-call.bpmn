<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
                  id="custom-worker-host-test"
                  targetNamespace="http://fleans.test/manual/40">
  <bpmn:process id="custom-worker-host-rest" name="Custom Worker Host - REST Call" isExecutable="true">
    <bpmn:startEvent id="start" name="Start" />
    <bpmn:sequenceFlow id="f1" sourceRef="start" targetRef="rest-call-task" />
    <bpmn:serviceTask id="rest-call-task" name="GET httpbin" type="rest-call">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="https://httpbin.org/get" target="url" />
          <zeebe:input source="GET" target="method" />
          <zeebe:output source="=__response.body" target="responseBody" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="f2" sourceRef="rest-call-task" targetRef="end" />
    <bpmn:endEvent id="end" name="End" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="d1">
    <bpmndi:BPMNPlane id="p1" bpmnElement="custom-worker-host-rest">
      <bpmndi:BPMNShape id="start_di" bpmnElement="start">
        <dc:Bounds x="100" y="80" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="rest_di" bpmnElement="rest-call-task">
        <dc:Bounds x="200" y="60" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_di" bpmnElement="end">
        <dc:Bounds x="380" y="80" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="f1_di" bpmnElement="f1">
        <di:waypoint x="136" y="98" />
        <di:waypoint x="200" y="98" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f2_di" bpmnElement="f2">
        <di:waypoint x="320" y="98" />
        <di:waypoint x="380" y="98" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
