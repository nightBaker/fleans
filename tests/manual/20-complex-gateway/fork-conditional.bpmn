<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:di="http://www.omg.org/spec/DD/20100524/DI">
  <process id="complex-gateway-fork" isExecutable="true">
    <startEvent id="start" />
    <scriptTask id="setup" scriptFormat="csharp">
      <script>_context.x = 7</script>
    </scriptTask>
    <complexGateway id="fork" default="s3" />
    <scriptTask id="highBranch" scriptFormat="csharp">
      <script>_context.high = true</script>
    </scriptTask>
    <scriptTask id="defaultBranch" scriptFormat="csharp">
      <script>_context.defaultTaken = true</script>
    </scriptTask>
    <endEvent id="endHigh" />
    <endEvent id="endDefault" />
    <sequenceFlow id="f1" sourceRef="start" targetRef="setup" />
    <sequenceFlow id="f2" sourceRef="setup" targetRef="fork" />
    <sequenceFlow id="s2" sourceRef="fork" targetRef="highBranch">
      <conditionExpression>x &gt; 5</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="s3" sourceRef="fork" targetRef="defaultBranch" />
    <sequenceFlow id="f3" sourceRef="highBranch" targetRef="endHigh" />
    <sequenceFlow id="f4" sourceRef="defaultBranch" targetRef="endDefault" />
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="complex-gateway-fork">
      <bpmndi:BPMNShape id="start_di" bpmnElement="start">
        <dc:Bounds x="160" y="200" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="setup_di" bpmnElement="setup">
        <dc:Bounds x="250" y="178" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="fork_di" bpmnElement="fork">
        <dc:Bounds x="400" y="193" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="highBranch_di" bpmnElement="highBranch">
        <dc:Bounds x="510" y="100" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="defaultBranch_di" bpmnElement="defaultBranch">
        <dc:Bounds x="510" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="endHigh_di" bpmnElement="endHigh">
        <dc:Bounds x="672" y="122" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="endDefault_di" bpmnElement="endDefault">
        <dc:Bounds x="672" y="282" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="f1_di" bpmnElement="f1">
        <di:waypoint x="196" y="218" />
        <di:waypoint x="250" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f2_di" bpmnElement="f2">
        <di:waypoint x="350" y="218" />
        <di:waypoint x="400" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="s2_di" bpmnElement="s2">
        <di:waypoint x="425" y="193" />
        <di:waypoint x="425" y="140" />
        <di:waypoint x="510" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="s3_di" bpmnElement="s3">
        <di:waypoint x="425" y="243" />
        <di:waypoint x="425" y="300" />
        <di:waypoint x="510" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f3_di" bpmnElement="f3">
        <di:waypoint x="610" y="140" />
        <di:waypoint x="672" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f4_di" bpmnElement="f4">
        <di:waypoint x="610" y="300" />
        <di:waypoint x="672" y="300" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
