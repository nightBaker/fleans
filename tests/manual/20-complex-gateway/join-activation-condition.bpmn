<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:di="http://www.omg.org/spec/DD/20100524/DI">
  <!-- Complex gateway join fires as soon as 1 of 2 tokens arrives -->
  <process id="complex-gateway-join-activation" isExecutable="true">
    <startEvent id="start" />
    <parallelGateway id="fork" />
    <scriptTask id="fastTask" scriptFormat="csharp">
      <script>_context.fast = true</script>
    </scriptTask>
    <scriptTask id="slowTask" scriptFormat="csharp">
      <!-- Simulates a slow branch; in a real test this would be a timer or user task -->
      <script>_context.slow = true</script>
    </scriptTask>
    <complexGateway id="join" activationCondition="_context._nroftoken &gt;= 1" />
    <scriptTask id="afterJoin" scriptFormat="csharp">
      <script>_context.joined = true</script>
    </scriptTask>
    <endEvent id="end" />
    <sequenceFlow id="f1" sourceRef="start" targetRef="fork" />
    <sequenceFlow id="f2" sourceRef="fork" targetRef="fastTask" />
    <sequenceFlow id="f3" sourceRef="fork" targetRef="slowTask" />
    <sequenceFlow id="f4" sourceRef="fastTask" targetRef="join" />
    <sequenceFlow id="f5" sourceRef="slowTask" targetRef="join" />
    <sequenceFlow id="f6" sourceRef="join" targetRef="afterJoin" />
    <sequenceFlow id="f7" sourceRef="afterJoin" targetRef="end" />
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="complex-gateway-join-activation">
      <bpmndi:BPMNShape id="start_di" bpmnElement="start">
        <dc:Bounds x="160" y="200" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="fork_di" bpmnElement="fork">
        <dc:Bounds x="250" y="193" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="fastTask_di" bpmnElement="fastTask">
        <dc:Bounds x="360" y="100" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="slowTask_di" bpmnElement="slowTask">
        <dc:Bounds x="360" y="260" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="join_di" bpmnElement="join">
        <dc:Bounds x="520" y="193" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="afterJoin_di" bpmnElement="afterJoin">
        <dc:Bounds x="630" y="178" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_di" bpmnElement="end">
        <dc:Bounds x="792" y="200" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="f1_di" bpmnElement="f1">
        <di:waypoint x="196" y="218" />
        <di:waypoint x="250" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f2_di" bpmnElement="f2">
        <di:waypoint x="275" y="193" />
        <di:waypoint x="275" y="140" />
        <di:waypoint x="360" y="140" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f3_di" bpmnElement="f3">
        <di:waypoint x="275" y="243" />
        <di:waypoint x="275" y="300" />
        <di:waypoint x="360" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f4_di" bpmnElement="f4">
        <di:waypoint x="460" y="140" />
        <di:waypoint x="545" y="140" />
        <di:waypoint x="545" y="193" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f5_di" bpmnElement="f5">
        <di:waypoint x="460" y="300" />
        <di:waypoint x="545" y="300" />
        <di:waypoint x="545" y="243" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f6_di" bpmnElement="f6">
        <di:waypoint x="570" y="218" />
        <di:waypoint x="630" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f7_di" bpmnElement="f7">
        <di:waypoint x="730" y="218" />
        <di:waypoint x="792" y="218" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
