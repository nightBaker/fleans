<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
             id="Definitions_1"
             targetNamespace="http://bpmn.io/schema/bpmn">

  <signal id="sig_order" name="orderSignal" />

  <process id="signal-start-process" isExecutable="true">

    <startEvent id="sigStart" name="Order Signal">
      <signalEventDefinition signalRef="sig_order" />
    </startEvent>

    <scriptTask id="task1" name="Process Order" scriptFormat="csharp">
      <script></script>
    </scriptTask>

    <endEvent id="end" name="Done" />

    <sequenceFlow id="f1" sourceRef="sigStart" targetRef="task1" />
    <sequenceFlow id="f2" sourceRef="task1" targetRef="end" />

  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="signal-start-process">
      <bpmndi:BPMNShape id="sigStart_di" bpmnElement="sigStart">
        <dc:Bounds x="179" y="99" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task1_di" bpmnElement="task1">
        <dc:Bounds x="270" y="77" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_di" bpmnElement="end">
        <dc:Bounds x="432" y="99" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="f1_di" bpmnElement="f1">
        <di:waypoint x="215" y="117" />
        <di:waypoint x="270" y="117" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f2_di" bpmnElement="f2">
        <di:waypoint x="370" y="117" />
        <di:waypoint x="432" y="117" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</definitions>
