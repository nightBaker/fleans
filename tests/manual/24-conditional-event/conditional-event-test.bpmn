<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
             id="Definitions_1"
             targetNamespace="http://bpmn.io/schema/bpmn">
  <process id="conditional-event-test" isExecutable="true">
    <startEvent id="start">
      <outgoing>f1</outgoing>
    </startEvent>

    <scriptTask id="set-initial" scriptFormat="csharp">
      <incoming>f1</incoming>
      <outgoing>f2</outgoing>
      <script>amount = 0;</script>
    </scriptTask>

    <intermediateCatchEvent id="wait-for-amount">
      <incoming>f2</incoming>
      <outgoing>f3</outgoing>
      <conditionalEventDefinition>
        <condition>amount > 500</condition>
      </conditionalEventDefinition>
    </intermediateCatchEvent>

    <scriptTask id="after-condition" scriptFormat="csharp">
      <incoming>f3</incoming>
      <outgoing>f4</outgoing>
      <script>result = "condition-met";</script>
    </scriptTask>

    <endEvent id="end">
      <incoming>f4</incoming>
    </endEvent>

    <sequenceFlow id="f1" sourceRef="start" targetRef="set-initial" />
    <sequenceFlow id="f2" sourceRef="set-initial" targetRef="wait-for-amount" />
    <sequenceFlow id="f3" sourceRef="wait-for-amount" targetRef="after-condition" />
    <sequenceFlow id="f4" sourceRef="after-condition" targetRef="end" />
  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="conditional-event-test">
      <bpmndi:BPMNShape id="start_di" bpmnElement="start">
        <dc:Bounds x="180" y="200" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="set-initial_di" bpmnElement="set-initial">
        <dc:Bounds x="270" y="178" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="wait-for-amount_di" bpmnElement="wait-for-amount">
        <dc:Bounds x="430" y="200" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="after-condition_di" bpmnElement="after-condition">
        <dc:Bounds x="530" y="178" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_di" bpmnElement="end">
        <dc:Bounds x="690" y="200" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="f1_di" bpmnElement="f1">
        <di:waypoint x="216" y="218" />
        <di:waypoint x="270" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f2_di" bpmnElement="f2">
        <di:waypoint x="370" y="218" />
        <di:waypoint x="430" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f3_di" bpmnElement="f3">
        <di:waypoint x="466" y="218" />
        <di:waypoint x="530" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f4_di" bpmnElement="f4">
        <di:waypoint x="630" y="218" />
        <di:waypoint x="690" y="218" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
