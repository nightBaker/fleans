<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
             id="Definitions_nested_tx_cancel_paths"
             targetNamespace="http://bpmn.io/schema/bpmn">

  <!--
    Fixture for test 46: Nested Transaction Sub-Process cancel paths.
    Covers Scenarios A (both TX commit), B (inner CancelEndEvent, outer commits),
    C (outer CancelEndEvent after inner commits).
    Scenario F cross-references nested-tx-hazard.bpmn.

    Design:
    - Inner TX: ExclusiveGateway branches on startup variable "innerShouldCancel".
      Set to true → inner fires CancelEndEvent. Default → inner completes normally.
      (EventBasedGateway inside nested Transaction does not register subscriptions —
       engine limitation at 2+ levels deep; use variable-driven branching instead.)
    - Outer TX: EventBasedGateway races two messages (1 level deep — supported).
      Send "trigger-outer-complete" for normal exit or "trigger-outer-cancel" for Cancel.

    Scenario A: start({}) → send "trigger-outer-complete"
    Scenario B: start({"innerShouldCancel":true}) → send "trigger-outer-complete"
    Scenario C: start({}) → send "trigger-outer-cancel"
  -->

  <process id="nested-tx-cancel-paths" isExecutable="true">

    <startEvent id="start" name="Start" />

    <!-- ═══════════════════════════════════════════
         Outer Transaction
         ═══════════════════════════════════════════ -->
    <transaction id="outer-tx" name="Outer TX">
      <startEvent id="outer-start" />

      <!-- ─────────────────────────────────────────
           Inner Transaction
           ───────────────────────────────────────── -->
      <transaction id="inner-tx" name="Inner TX">
        <startEvent id="inner-start" />

        <!-- Variable-driven fork: cancel or proceed based on startup variable -->
        <exclusiveGateway id="inner-fork" name="Cancel?" gatewayDirection="Diverging" />

        <!-- Normal path: compensable work task -->
        <scriptTask id="inner-work" name="Inner Work" scriptFormat="csharp">
          <script>_context.innerDone = true</script>
        </scriptTask>

        <!-- Compensation handler for inner-work -->
        <scriptTask id="inner-compensate" name="Inner Compensate" scriptFormat="csharp">
          <script>_context.innerCompensated = true</script>
        </scriptTask>

        <endEvent id="inner-end" name="Inner End" />

        <!-- Cancel path -->
        <endEvent id="inner-cancel-end" name="Inner Cancel">
          <cancelEventDefinition />
        </endEvent>

        <!-- Compensation boundary on inner-work -->
        <boundaryEvent id="inner-compensate-boundary" attachedToRef="inner-work" cancelActivity="false">
          <compensateEventDefinition />
        </boundaryEvent>

        <!-- inner-fork: "innerShouldCancel == true" → cancel path; default → normal -->
        <sequenceFlow id="isf1" sourceRef="inner-start" targetRef="inner-fork" />
        <sequenceFlow id="isf-cancel" sourceRef="inner-fork" targetRef="inner-cancel-end">
          <conditionExpression>_context.innerShouldCancel == true</conditionExpression>
        </sequenceFlow>
        <sequenceFlow id="isf-normal" sourceRef="inner-fork" targetRef="inner-work" />
        <sequenceFlow id="isf2" sourceRef="inner-work" targetRef="inner-end" />

        <!-- Compensation association: boundary → handler -->
        <association id="ca-inner-compensate" associationDirection="One"
                     sourceRef="inner-compensate-boundary" targetRef="inner-compensate" />
      </transaction>

      <!-- Cancel boundary on inner-tx (fires when inner TX cancels) -->
      <boundaryEvent id="inner-tx-cancel-boundary" attachedToRef="inner-tx" cancelActivity="true">
        <cancelEventDefinition />
      </boundaryEvent>

      <!-- Merge both inner-tx exit paths before outer decision -->
      <exclusiveGateway id="join-after-inner" name="Join After Inner" gatewayDirection="Converging" />

      <!-- Outer decision: normal completion vs cancel (1-level-deep ICE — supported) -->
      <eventBasedGateway id="outer-decision" name="Outer Decision" />

      <!-- Branch A: outer completes normally -->
      <intermediateCatchEvent id="trigger-outer-complete-catch" name="Trigger Outer Complete">
        <messageEventDefinition messageRef="msgTriggerOuterComplete" />
      </intermediateCatchEvent>
      <endEvent id="outer-end" name="Outer End" />

      <!-- Branch B: outer cancels -->
      <intermediateCatchEvent id="trigger-outer-cancel-catch" name="Trigger Outer Cancel">
        <messageEventDefinition messageRef="msgTriggerOuterCancel" />
      </intermediateCatchEvent>
      <endEvent id="outer-cancel-end" name="Outer Cancel">
        <cancelEventDefinition />
      </endEvent>

      <sequenceFlow id="osf1" sourceRef="outer-start" targetRef="inner-tx" />
      <sequenceFlow id="osf2" sourceRef="inner-tx" targetRef="join-after-inner" />
      <sequenceFlow id="osf3" sourceRef="inner-tx-cancel-boundary" targetRef="join-after-inner" />
      <sequenceFlow id="osf4" sourceRef="join-after-inner" targetRef="outer-decision" />
      <sequenceFlow id="osf5" sourceRef="outer-decision" targetRef="trigger-outer-complete-catch" />
      <sequenceFlow id="osf6" sourceRef="trigger-outer-complete-catch" targetRef="outer-end" />
      <sequenceFlow id="osf7" sourceRef="outer-decision" targetRef="trigger-outer-cancel-catch" />
      <sequenceFlow id="osf8" sourceRef="trigger-outer-cancel-catch" targetRef="outer-cancel-end" />
    </transaction>

    <!-- Cancel boundary on outer-tx → recovery flow -->
    <boundaryEvent id="outer-tx-cancel-boundary" attachedToRef="outer-tx" cancelActivity="true">
      <cancelEventDefinition />
    </boundaryEvent>
    <endEvent id="cancel-recovery-end" name="Cancelled End" />

    <!-- Error boundary on outer-tx (errorCode 503 = Hazard cascade) -->
    <boundaryEvent id="outer-tx-error-boundary" attachedToRef="outer-tx" cancelActivity="true">
      <errorEventDefinition errorRef="hazardError" />
    </boundaryEvent>
    <endEvent id="hazard-recovery-end" name="Hazard End">
      <errorEventDefinition />
    </endEvent>

    <endEvent id="process-end" name="Process End" />

    <sequenceFlow id="sf1" sourceRef="start" targetRef="outer-tx" />
    <sequenceFlow id="sf2" sourceRef="outer-tx" targetRef="process-end" />
    <sequenceFlow id="sf3" sourceRef="outer-tx-cancel-boundary" targetRef="cancel-recovery-end" />
    <sequenceFlow id="sf4" sourceRef="outer-tx-error-boundary" targetRef="hazard-recovery-end" />
  </process>

  <!-- Messages for the outer EventBasedGateway (1-level deep inside outer-tx — supported) -->
  <message id="msgTriggerOuterComplete" name="trigger-outer-complete" />
  <message id="msgTriggerOuterCancel" name="trigger-outer-cancel" />

  <!-- Error for outer TX Hazard boundary -->
  <error id="hazardError" name="HazardError" errorCode="503" />

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="nested-tx-cancel-paths">
      <bpmndi:BPMNShape id="Shape_start" bpmnElement="start">
        <dc:Bounds x="152" y="82" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_outer-tx" bpmnElement="outer-tx" isExpanded="true">
        <dc:Bounds x="240" y="40" width="800" height="500" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_outer-start" bpmnElement="outer-start">
        <dc:Bounds x="272" y="262" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_inner-tx" bpmnElement="inner-tx" isExpanded="true">
        <dc:Bounds x="360" y="100" width="440" height="320" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_inner-start" bpmnElement="inner-start">
        <dc:Bounds x="392" y="242" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_inner-fork" bpmnElement="inner-fork">
        <dc:Bounds x="465" y="237" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_inner-work" bpmnElement="inner-work">
        <dc:Bounds x="572" y="220" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_inner-compensate" bpmnElement="inner-compensate">
        <dc:Bounds x="572" y="330" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_inner-end" bpmnElement="inner-end">
        <dc:Bounds x="722" y="242" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_inner-cancel-end" bpmnElement="inner-cancel-end">
        <dc:Bounds x="465" y="350" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_inner-compensate-boundary" bpmnElement="inner-compensate-boundary">
        <dc:Bounds x="604" y="282" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_inner-tx-cancel-boundary" bpmnElement="inner-tx-cancel-boundary">
        <dc:Bounds x="574" y="402" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_join-after-inner" bpmnElement="join-after-inner">
        <dc:Bounds x="850" y="255" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_outer-decision" bpmnElement="outer-decision">
        <dc:Bounds x="955" y="255" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_trigger-outer-complete-catch" bpmnElement="trigger-outer-complete-catch">
        <dc:Bounds x="965" y="122" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_outer-end" bpmnElement="outer-end">
        <dc:Bounds x="965" y="62" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_trigger-outer-cancel-catch" bpmnElement="trigger-outer-cancel-catch">
        <dc:Bounds x="965" y="412" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_outer-cancel-end" bpmnElement="outer-cancel-end">
        <dc:Bounds x="965" y="482" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_outer-tx-cancel-boundary" bpmnElement="outer-tx-cancel-boundary">
        <dc:Bounds x="642" y="522" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_outer-tx-error-boundary" bpmnElement="outer-tx-error-boundary">
        <dc:Bounds x="712" y="522" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_cancel-recovery-end" bpmnElement="cancel-recovery-end">
        <dc:Bounds x="642" y="610" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_hazard-recovery-end" bpmnElement="hazard-recovery-end">
        <dc:Bounds x="712" y="610" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_process-end" bpmnElement="process-end">
        <dc:Bounds x="1102" y="62" width="36" height="36" />
      </bpmndi:BPMNShape>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</definitions>
