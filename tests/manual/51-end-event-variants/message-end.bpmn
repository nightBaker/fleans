<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
             id="Definitions_messageEnd"
             targetNamespace="http://bpmn.io/schema/bpmn">

  <message id="msg1" name="orderCompleted" />

  <process id="messageEndProcess" isExecutable="true">

    <startEvent id="start" name="Start" />

    <endEvent id="message_end" name="Order Completed">
      <messageEventDefinition id="msgDef1" messageRef="msg1" />
    </endEvent>

    <sequenceFlow id="f1" sourceRef="start" targetRef="message_end" />

  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="messageEndProcess">
      <bpmndi:BPMNShape id="start_shape" bpmnElement="start">
        <dc:Bounds x="152" y="182" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="message_end_shape" bpmnElement="message_end">
        <dc:Bounds x="272" y="182" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="f1_edge" bpmnElement="f1">
        <di:waypoint x="188" y="200" />
        <di:waypoint x="272" y="200" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</definitions>
