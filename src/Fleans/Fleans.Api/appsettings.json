{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RateLimiting": {
    "WorkflowMutation": { "Window": 60, "PermitLimit": 100 },
    "TaskOperation": { "Window": 60, "PermitLimit": 200 },
    "Read": { "Window": 60, "PermitLimit": 300 },
    "Admin": { "Window": 60, "PermitLimit": 20 }
  }
}
