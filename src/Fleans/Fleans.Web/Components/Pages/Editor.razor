@page "/editor"
@page "/editor/{ProcessDefinitionKey}"
@page "/editor/{ProcessDefinitionKey}/{Version:int}"
@rendermode InteractiveServer
@using System.Text.Json
@using Fleans.Application
@using Fleans.Application.QueryModels
@using Fleans.Infrastructure.Bpmn
@using Microsoft.FluentUI.AspNetCore.Components
@inject IWorkflowQueryService QueryService
@inject IWorkflowCommandService CommandService
@inject IBpmnConverter BpmnConverter
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ILogger<Editor> Logger
@implements IAsyncDisposable

<PageTitle>BPMN Editor</PageTitle>

<div class="editor-page">
    <div class="editor-toolbar">
        <FluentButton Appearance="Appearance.Stealth"
                      IconStart="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.ArrowLeft())"
                      @onclick="GoBack">
            Back
        </FluentButton>

        @if (isEditingProcessId)
        {
            <FluentTextField @bind-Value="processIdEdit"
                             Autofocus="true"
                             @onkeydown="OnProcessIdKeyDown"
                             @onblur="ConfirmProcessIdEdit"
                             Placeholder="Process ID"
                             Style="width: 200px;" />
            @if (processIdError != null)
            {
                <FluentBadge Color="Color.Error">@processIdError</FluentBadge>
            }
        }
        else if (ActiveTab != null && !string.IsNullOrEmpty(ActiveTab.ProcessKey))
        {
            <span class="process-id-toolbar" @onclick="StartProcessIdEdit" title="Click to edit process ID">
                @ActiveTab.ProcessKey
            </span>
            @if (ActiveTab.Version.HasValue)
            {
                <FluentBadge Color="Color.Accent">v@(ActiveTab.Version)</FluentBadge>
            }
        }

        <div class="toolbar-spacer"></div>

        <FluentButton Appearance="Appearance.Stealth"
                      IconStart="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.Add())"
                      @onclick="NewDiagramTab">
            New Diagram
        </FluentButton>

        <FluentInputFile @ref="fileUploader"
                         DragDropZoneVisible="false"
                         Mode="InputFileMode.SaveToTemporaryFolder"
                         Multiple="false"
                         AnchorId="ImportBpmnButton"
                         MaximumFileSize="@(10 * 1024 * 1024)"
                         Accept=".bpmn,.xml"
                         OnCompleted="@OnImportFileSelected" />

        <FluentButton Id="ImportBpmnButton"
                      Appearance="Appearance.Neutral"
                      IconStart="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.ArrowUpload())">
            Import BPMN
        </FluentButton>

        <FluentButton Appearance="Appearance.Neutral"
                      IconStart="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.ArrowDownload())"
                      @onclick="DownloadXml">
            Download XML
        </FluentButton>

        <FluentButton Appearance="Appearance.Accent"
                      IconStart="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.Rocket())"
                      Loading="@isDeploying"
                      @onclick="ShowDeployDialog">
            Deploy
        </FluentButton>
    </div>

    <div class="editor-tab-bar">
        @foreach (var tab in tabs)
        {
            var t = tab;
            var classes = "editor-tab" + (t.Id == activeTabId ? " editor-tab--active" : "");
            <div class="@classes" @onclick="() => SwitchTab(t.Id)" title="@t.Label">
                <span class="editor-tab__label">@t.Label</span>
                @if (t.Dirty)
                {
                    <span class="editor-tab__dirty" title="Unsaved changes">●</span>
                }
                <button type="button"
                        class="editor-tab__close"
                        title="Close tab"
                        @onclick="() => RequestCloseTab(t.Id)"
                        @onclick:stopPropagation="true">×</button>
            </div>
        }
    </div>

    @if (errorMessage != null)
    {
        <FluentMessageBar Intent="MessageIntent.Error" Dismissible="true" OnDismissed="@(() => errorMessage = null)"
                          Style="margin: 8px 16px 0;">
            @errorMessage
        </FluentMessageBar>
    }

    @if (successMessage != null)
    {
        <FluentMessageBar Intent="MessageIntent.Success" Dismissible="true" OnDismissed="@(() => successMessage = null)"
                          Style="margin: 8px 16px 0;">
            @successMessage
        </FluentMessageBar>
    }

    <div class="editor-content">
        <div id="editor-canvas" class="editor-canvas"></div>

        @if (selectedElement != null)
        {
            <ElementPropertiesPanel Element="@selectedElement" OnElementReplaced="OnElementReplaced" />
        }
    </div>
</div>

@if (showDeployDialog)
{
    <div class="deploy-overlay" @onclick="CancelDeploy"></div>
    <div class="deploy-dialog">
        <FluentStack Orientation="Orientation.Vertical" Gap="16px">
            <FluentLabel Typo="Typography.PaneHeader">Confirm Deployment</FluentLabel>
            <p><strong>Process Key:</strong> @deployProcessKey</p>
            <p><strong>Version:</strong> @deployNextVersion</p>
            <p>This will deploy a new version of the workflow definition.</p>
            <FluentStack Orientation="Orientation.Horizontal" Gap="8px" Justify="JustifyContent.FlexEnd">
                <FluentButton Appearance="Appearance.Neutral" @onclick="CancelDeploy">Cancel</FluentButton>
                <FluentButton Appearance="Appearance.Accent" @onclick="ConfirmDeploy">Deploy</FluentButton>
            </FluentStack>
        </FluentStack>
    </div>
}

@if (tabPendingClose != null)
{
    <div class="deploy-overlay" @onclick="CancelCloseTab"></div>
    <div class="deploy-dialog">
        <FluentStack Orientation="Orientation.Vertical" Gap="16px">
            <FluentLabel Typo="Typography.PaneHeader">Discard unsaved changes?</FluentLabel>
            <p>Tab "<strong>@tabPendingClose.Label</strong>" has unsaved changes. Discarding will close the tab and lose those changes.</p>
            <FluentStack Orientation="Orientation.Horizontal" Gap="8px" Justify="JustifyContent.FlexEnd">
                <FluentButton Appearance="Appearance.Neutral" @onclick="CancelCloseTab">Cancel</FluentButton>
                <FluentButton Appearance="Appearance.Accent" @onclick="ConfirmCloseTab">Discard</FluentButton>
            </FluentStack>
        </FluentStack>
    </div>
}

@code {
    private const int MaxTabs = 10;
    private const string StorageKey = "fleans.editor.tabs.v1";

    [Parameter] public string? ProcessDefinitionKey { get; set; }
    [Parameter] public int? Version { get; set; }

    private FluentInputFile? fileUploader;
    private DotNetObjectReference<Editor>? dotNetRef;
    private bool isDeploying;
    private bool showDeployDialog;
    private string? errorMessage;
    private string? successMessage;
    private bool editorInitialized;

    private string? deployProcessKey;
    private string deployNextVersion = "";
    private string? pendingBpmnXml;
    private Domain.WorkflowDefinition? pendingWorkflow;

    private ElementPropertiesPanel.BpmnElementData? selectedElement;

    private string processIdEdit = "";
    private bool isEditingProcessId;
    private string? processIdError;

    private readonly List<TabSession> tabs = new();
    private string? activeTabId;
    private TabSession? tabPendingClose;

    private TabSession? ActiveTab =>
        activeTabId == null ? null : tabs.FirstOrDefault(t => t.Id == activeTabId);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        dotNetRef = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("bpmnEditor.init", "editor-canvas", dotNetRef);
        await JS.InvokeVoidAsync("bpmnEditor.registerDirtyCallback", dotNetRef);
        await JS.InvokeVoidAsync("bpmnEditor.registerBeforeUnloadWarning", dotNetRef);
        editorInitialized = true;

        await RestoreTabsFromStorage();

        if (!string.IsNullOrEmpty(ProcessDefinitionKey))
        {
            await OpenFromWorkflow(ProcessDefinitionKey, Version);
        }
        else if (tabs.Count == 0)
        {
            await AddBlankTab(activate: true);
        }
        else
        {
            await ActivateTab(activeTabId ?? tabs[0].Id, saveOutgoing: false);
        }

        await PersistTabs();
        StateHasChanged();
    }

    [JSInvokable]
    public Task OnModelerDirty()
    {
        var active = ActiveTab;
        if (active != null && !active.Dirty)
        {
            active.Dirty = true;
            _ = UpdateDirtyFlagAndPersist();
            return InvokeAsync(StateHasChanged);
        }
        return Task.CompletedTask;
    }

    [JSInvokable]
    public void OnElementSelected(ElementPropertiesPanel.BpmnElementData elementData)
    {
        selectedElement = elementData;
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnElementDeselected()
    {
        selectedElement = null;
        InvokeAsync(StateHasChanged);
    }

    private void OnElementReplaced(ElementPropertiesPanel.BpmnElementData newElement)
    {
        selectedElement = newElement;
        StateHasChanged();
    }

    private void StartProcessIdEdit()
    {
        if (ActiveTab == null) return;
        processIdEdit = ActiveTab.ProcessKey;
        processIdError = null;
        isEditingProcessId = true;
    }

    private async Task OnProcessIdKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await ConfirmProcessIdEdit();
        }
        else if (e.Key == "Escape")
        {
            isEditingProcessId = false;
            processIdError = null;
        }
    }

    private async Task ConfirmProcessIdEdit()
    {
        if (!isEditingProcessId || ActiveTab == null) return;

        var newId = processIdEdit.Trim();

        if (string.IsNullOrEmpty(newId))
        {
            processIdError = "ID cannot be empty";
            return;
        }

        if (newId.Contains(' '))
        {
            processIdError = "ID cannot contain spaces";
            return;
        }

        if (!System.Text.RegularExpressions.Regex.IsMatch(newId, @"^[a-zA-Z_][\w.\-]*$"))
        {
            processIdError = "ID must start with a letter or underscore";
            return;
        }

        if (newId != ActiveTab.ProcessKey)
        {
            await JS.InvokeAsync<bool>("bpmnEditor.updateProcessId", newId);
            ActiveTab.ProcessKey = newId;
            ActiveTab.Label = newId;
            await PersistTabs();
        }

        isEditingProcessId = false;
        processIdError = null;
    }

    private async Task NewDiagramTab()
    {
        if (!editorInitialized) return;
        if (!EnsureCapacity()) return;
        await AddBlankTab(activate: true);
        await PersistTabs();
        StateHasChanged();
    }

    private async Task OnImportFileSelected(IEnumerable<FluentInputFileEventArgs> files)
    {
        var file = files.FirstOrDefault();
        if (file == null) return;

        try
        {
            if (!string.IsNullOrEmpty(file.ErrorMessage))
            {
                errorMessage = file.ErrorMessage;
                return;
            }

            if (file.LocalFile == null || !file.LocalFile.Exists)
            {
                errorMessage = "File not found. Please try again.";
                return;
            }

            if (!EnsureCapacity()) return;

            errorMessage = null;
            successMessage = null;

            var bpmnXml = await File.ReadAllTextAsync(file.LocalFile.FullName);
            await SaveActiveTabXml();

            var tab = new TabSession
            {
                Id = Guid.NewGuid().ToString("N"),
                Label = Path.GetFileNameWithoutExtension(file.Name),
                ProcessKey = "",
                Version = null,
                BpmnXml = bpmnXml,
                LastSavedXml = bpmnXml,
                Dirty = false
            };
            tabs.Add(tab);
            await ActivateTab(tab.Id, saveOutgoing: false);
            successMessage = $"Imported {file.Name}";
            await PersistTabs();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to import BPMN file");
            errorMessage = $"Failed to import file: {ex.Message}";
        }
        finally
        {
            file.LocalFile?.Delete();
        }
    }

    private async Task DownloadXml()
    {
        if (!editorInitialized || ActiveTab == null) return;

        try
        {
            var xml = await JS.InvokeAsync<string>("bpmnEditor.getXml");
            if (string.IsNullOrEmpty(xml)) return;

            var bytes = System.Text.Encoding.UTF8.GetBytes(xml);
            var base64 = Convert.ToBase64String(bytes);
            var filename = !string.IsNullOrEmpty(ActiveTab.ProcessKey) ? $"{ActiveTab.ProcessKey}.bpmn" : "diagram.bpmn";
            await JS.InvokeVoidAsync("bpmnEditor.downloadXml", base64, filename);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to download XML");
            errorMessage = $"Failed to download: {ex.Message}";
        }
    }

    private async Task ShowDeployDialog()
    {
        if (!editorInitialized || ActiveTab == null) return;

        try
        {
            errorMessage = null;
            successMessage = null;

            var xml = await JS.InvokeAsync<string>("bpmnEditor.getXml");
            if (string.IsNullOrEmpty(xml))
            {
                errorMessage = "No diagram to deploy.";
                return;
            }

            using var stream = new MemoryStream(System.Text.Encoding.UTF8.GetBytes(xml));
            var workflow = await BpmnConverter.ConvertFromXmlAsync(stream);

            pendingBpmnXml = xml;
            pendingWorkflow = workflow;
            deployProcessKey = workflow.WorkflowId;

            var definitions = await QueryService.GetAllProcessDefinitions();
            var existing = definitions
                .Where(d => d.ProcessDefinitionKey == deployProcessKey)
                .OrderByDescending(d => d.Version)
                .FirstOrDefault();
            var nextVersion = existing != null ? existing.Version + 1 : 1;
            deployNextVersion = $"v{nextVersion}";

            showDeployDialog = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to prepare deployment");
            errorMessage = $"Invalid BPMN: {ex.Message}";
        }
    }

    private void CancelDeploy()
    {
        showDeployDialog = false;
        pendingBpmnXml = null;
        pendingWorkflow = null;
    }

    private async Task ConfirmDeploy()
    {
        if (pendingWorkflow == null || pendingBpmnXml == null || ActiveTab == null) return;

        try
        {
            isDeploying = true;
            showDeployDialog = false;

            var deployed = await CommandService.DeployWorkflow(pendingWorkflow, pendingBpmnXml);
            ActiveTab.ProcessKey = deployed.ProcessDefinitionKey;
            ActiveTab.Version = deployed.Version;
            ActiveTab.Label = deployed.ProcessDefinitionKey;
            ActiveTab.LastSavedXml = pendingBpmnXml;
            ActiveTab.BpmnXml = pendingBpmnXml;
            ActiveTab.Dirty = false;

            successMessage = $"Deployed '{deployed.ProcessDefinitionKey}' v{deployed.Version} ({deployed.ActivitiesCount} activities, {deployed.SequenceFlowsCount} flows)";
            await PersistTabs();
            await UpdateDirtyFlagAndPersist();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to deploy workflow");
            errorMessage = $"Deployment failed: {ex.Message}";
        }
        finally
        {
            isDeploying = false;
            pendingBpmnXml = null;
            pendingWorkflow = null;
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/workflows");
    }

    // ---- Tab management --------------------------------------------------

    private bool EnsureCapacity()
    {
        if (tabs.Count >= MaxTabs)
        {
            errorMessage = $"Tab limit reached ({MaxTabs}). Close a tab to open another.";
            return false;
        }
        return true;
    }

    private async Task AddBlankTab(bool activate)
    {
        var id = Guid.NewGuid().ToString("N");
        var label = $"Untitled-{tabs.Count(t => t.Label.StartsWith("Untitled-", StringComparison.Ordinal)) + 1}";

        // Capture bpmn-js's built-in empty diagram XML so tabs all share the same
        // "blank canvas" starting point and round-trip through loadXml correctly.
        await JS.InvokeVoidAsync("bpmnEditor.newDiagram");
        var xml = await JS.InvokeAsync<string>("bpmnEditor.getXml") ?? "";

        var tab = new TabSession
        {
            Id = id,
            Label = label,
            ProcessKey = "",
            Version = null,
            BpmnXml = xml,
            LastSavedXml = xml,
            Dirty = false
        };
        tabs.Add(tab);

        if (activate)
        {
            activeTabId = id;
            await RefreshActiveProcessId();
        }
    }

    private async Task OpenFromWorkflow(string processKey, int? version)
    {
        // If already open with the same (key, version), just activate.
        var existing = tabs.FirstOrDefault(t =>
            t.ProcessKey == processKey &&
            t.Version == version);
        if (existing != null)
        {
            await ActivateTab(existing.Id, saveOutgoing: true);
            return;
        }

        if (!EnsureCapacity()) return;

        try
        {
            string bpmnXml = (version.HasValue
                ? await QueryService.GetBpmnXmlByKeyAndVersion(processKey, version.Value)
                : await QueryService.GetBpmnXmlByKey(processKey)) ?? "";

            await SaveActiveTabXml();

            var tab = new TabSession
            {
                Id = Guid.NewGuid().ToString("N"),
                Label = processKey,
                ProcessKey = processKey,
                Version = version,
                BpmnXml = bpmnXml,
                LastSavedXml = bpmnXml,
                Dirty = false
            };
            tabs.Add(tab);
            await ActivateTab(tab.Id, saveOutgoing: false);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load BPMN for key {Key}", processKey);
            errorMessage = $"Failed to load workflow: {ex.Message}";
        }
    }

    private async Task SwitchTab(string tabId)
    {
        if (tabId == activeTabId) return;
        await ActivateTab(tabId, saveOutgoing: true);
        await PersistTabs();
    }

    private async Task ActivateTab(string tabId, bool saveOutgoing)
    {
        var incoming = tabs.FirstOrDefault(t => t.Id == tabId);
        if (incoming == null) return;

        if (saveOutgoing)
        {
            await SaveActiveTabXml();
        }

        activeTabId = tabId;

        try
        {
            await JS.InvokeVoidAsync("bpmnEditor.loadXml", incoming.BpmnXml);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load BPMN for tab {TabId}", tabId);
            errorMessage = $"Failed to load tab: {ex.Message}";
            return;
        }

        selectedElement = null;
        await RefreshActiveProcessId();
        StateHasChanged();
    }

    private async Task SaveActiveTabXml()
    {
        if (!editorInitialized || ActiveTab == null) return;
        try
        {
            var xml = await JS.InvokeAsync<string>("bpmnEditor.getXml");
            if (!string.IsNullOrEmpty(xml))
            {
                ActiveTab.BpmnXml = xml;
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to snapshot XML for active tab");
        }
    }

    private async Task RefreshActiveProcessId()
    {
        if (!editorInitialized || ActiveTab == null) return;
        var id = await JS.InvokeAsync<string>("bpmnEditor.getProcessId");
        if (!string.IsNullOrEmpty(id))
        {
            ActiveTab.ProcessKey = id;
            if (string.IsNullOrEmpty(ActiveTab.Label) || ActiveTab.Label.StartsWith("Untitled-", StringComparison.Ordinal))
            {
                ActiveTab.Label = id;
            }
        }
    }

    private void RequestCloseTab(string tabId)
    {
        var tab = tabs.FirstOrDefault(t => t.Id == tabId);
        if (tab == null) return;
        if (tab.Dirty)
        {
            tabPendingClose = tab;
            StateHasChanged();
        }
        else
        {
            _ = PerformCloseTab(tab);
        }
    }

    private void CancelCloseTab()
    {
        tabPendingClose = null;
    }

    private async Task ConfirmCloseTab()
    {
        var tab = tabPendingClose;
        tabPendingClose = null;
        if (tab != null)
        {
            await PerformCloseTab(tab);
        }
    }

    private async Task PerformCloseTab(TabSession tab)
    {
        var idx = tabs.IndexOf(tab);
        var wasActive = tab.Id == activeTabId;
        tabs.RemoveAt(idx);

        if (tabs.Count == 0)
        {
            // Never leave the editor with zero tabs — fall back to a fresh blank.
            await AddBlankTab(activate: true);
        }
        else if (wasActive)
        {
            var nextIdx = Math.Min(idx, tabs.Count - 1);
            await ActivateTab(tabs[nextIdx].Id, saveOutgoing: false);
        }

        await PersistTabs();
        await UpdateDirtyFlagAndPersist();
        StateHasChanged();
    }

    // ---- Persistence -----------------------------------------------------

    private async Task PersistTabs()
    {
        try
        {
            // Snapshot current modeler XML into the active tab before serializing,
            // so a refresh restores the in-memory edits up to this point.
            await SaveActiveTabXml();

            var payload = new TabsPayload
            {
                ActiveTabId = activeTabId,
                SavedAt = DateTimeOffset.UtcNow,
                Tabs = tabs.Select(t => new TabSessionDto
                {
                    Id = t.Id,
                    Label = t.Label,
                    ProcessKey = t.ProcessKey,
                    Version = t.Version,
                    BpmnXml = t.BpmnXml,
                    LastSavedXml = t.LastSavedXml,
                    Dirty = t.Dirty
                }).ToList()
            };
            var json = JsonSerializer.Serialize(payload);
            var ok = await JS.InvokeAsync<bool>("bpmnEditor.writeStorage", StorageKey, json);
            if (!ok)
            {
                Logger.LogDebug("localStorage write for editor tabs was rejected (quota?)");
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to persist editor tabs");
        }
    }

    private async Task RestoreTabsFromStorage()
    {
        try
        {
            var json = await JS.InvokeAsync<string?>("bpmnEditor.readStorage", StorageKey);
            if (string.IsNullOrWhiteSpace(json)) return;

            var payload = JsonSerializer.Deserialize<TabsPayload>(json);
            if (payload?.Tabs == null) return;

            foreach (var dto in payload.Tabs.Take(MaxTabs))
            {
                if (string.IsNullOrEmpty(dto.Id) || string.IsNullOrEmpty(dto.BpmnXml))
                {
                    continue;
                }
                tabs.Add(new TabSession
                {
                    Id = dto.Id,
                    Label = string.IsNullOrEmpty(dto.Label) ? "Untitled" : dto.Label,
                    ProcessKey = dto.ProcessKey ?? "",
                    Version = dto.Version,
                    BpmnXml = dto.BpmnXml,
                    LastSavedXml = dto.LastSavedXml ?? dto.BpmnXml,
                    Dirty = dto.Dirty
                });
            }

            if (tabs.Count > 0)
            {
                activeTabId = payload.ActiveTabId != null && tabs.Any(t => t.Id == payload.ActiveTabId)
                    ? payload.ActiveTabId
                    : tabs[0].Id;
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to restore editor tabs from localStorage");
        }
    }

    private async Task UpdateDirtyFlagAndPersist()
    {
        var anyDirty = tabs.Any(t => t.Dirty);
        try
        {
            await JS.InvokeVoidAsync("bpmnEditor.setDirtyTabsFlag", anyDirty);
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "setDirtyTabsFlag interop failed");
        }
        await PersistTabs();
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("bpmnEditor.destroy");
        }
        catch
        {
            // JS interop may fail during disposal
        }

        dotNetRef?.Dispose();
    }

    // ---- Types -----------------------------------------------------------

    private sealed class TabSession
    {
        public string Id { get; set; } = "";
        public string Label { get; set; } = "";
        public string ProcessKey { get; set; } = "";
        public int? Version { get; set; }
        public string BpmnXml { get; set; } = "";
        public string LastSavedXml { get; set; } = "";
        public bool Dirty { get; set; }
    }

    private sealed class TabsPayload
    {
        public string? ActiveTabId { get; set; }
        public DateTimeOffset SavedAt { get; set; }
        public List<TabSessionDto> Tabs { get; set; } = new();
    }

    private sealed class TabSessionDto
    {
        public string Id { get; set; } = "";
        public string Label { get; set; } = "";
        public string ProcessKey { get; set; } = "";
        public int? Version { get; set; }
        public string BpmnXml { get; set; } = "";
        public string? LastSavedXml { get; set; }
        public bool Dirty { get; set; }
    }
}
